{
  "name": "ok-obsidian-plugin-image",
  "version": "0.2.0",
  "description": "Upload Obsidian images to remote stores.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "changeset version && node version-bump.mjs && git add manifest.json versions.json",
    "release": "npm run build"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "image-upload",
    "github"
  ],
  "author": "ok de packages",
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@types/node": "^20.17.6",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.24.0",
    "obsidian": "^1.7.2",
    "tslib": "^2.8.1",
    "typescript": "^5.6.3"
  }
}
